{
  "name": "github-pr-filter",
  "version": "0.5.0",
  "private": true,
  "packageManager": "bun@1.3.11",
  "license": "MIT",
  "description": "A focused Chromium and Firefox extension for switching GitHub pull-request lifecycle views.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tstejl/github-pr-filter.git"
  },
  "bugs": {
    "url": "https://github.com/tstejl/github-pr-filter/issues"
  },
  "homepage": "https://github.com/tstejl/github-pr-filter#readme",
  "scripts": {
    "test": "bun run test:unit",
    "test:unit": "bun test test",
    "test:e2e": "bun run test:e2e:chromium && bun run test:e2e:firefox",
    "test:e2e:chromium": "E2E_BROWSER=chromium bun test ./e2e/lifecycle.e2e.js",
    "test:e2e:firefox": "E2E_BROWSER=firefox bun test ./e2e/lifecycle.e2e.js",
    "check": "bun test test",
    "lint:firefox": "web-ext lint",
    "build:firefox": "web-ext build --overwrite-dest",
    "release:package": "bun scripts/package-release.js"
  },
  "webExt": {
    "sourceDir": ".",
    "artifactsDir": "dist/firefox",
    "ignoreFiles": [
      ".codebase-memory",
      "dist",
      "node_modules/**",
      "test",
      "e2e",
      "scripts",
      ".github",
      "package.json",
      "bun.lock",
      "README.md",
      "CONTRIBUTING.md",
      "CHANGELOG.md"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "selenium-webdriver": "^4.46.0",
    "web-ext": "10.5.0"
  }
}

{
  "name": "github-pr-filter",
  "version": "0.5.0",
  "private": true,
  "packageManager": "bun@1.3.11",
  "license": "MIT",
  "description": "A focused Chromium and Firefox extension for switching GitHub pull-request lifecycle views.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tstejl/github-pr-filter.git"
  },
  "bugs": {
    "url": "https://github.com/tstejl/github-pr-filter/issues"
  },
  "homepage": "https://github.com/tstejl/github-pr-filter#readme",
  "scripts": {
    "build": "bun scripts/build-extension.js",
    "storybook": "storybook dev --port 6006 --no-open",
    "storybook:build": "storybook build --output-dir dist/storybook",
    "test": "bun run test:unit",
    "test:unit": "bun run build && bun test test",
    "test:e2e": "bun run test:e2e:chromium && bun run test:e2e:firefox",
    "test:e2e:chromium": "bun run build && E2E_BROWSER=chromium bun test ./e2e/lifecycle.e2e.js",
    "test:e2e:firefox": "bun run build && E2E_BROWSER=firefox bun test ./e2e/lifecycle.e2e.js",
    "test:visual": "bunx playwright test --config playwright.visual.config.ts",
    "check": "tsc --noEmit && bun run test:unit",
    "lint:firefox": "bun run build && web-ext lint",
    "build:firefox": "bun run build && web-ext build --overwrite-dest",
    "release:package": "bun run build && bun scripts/package-release.js"
  },
  "webExt": {
    "sourceDir": "dist/extension",
    "artifactsDir": "dist/firefox"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@storybook/addon-a11y": "10.5.0",
    "@storybook/html-vite": "10.5.0",
    "selenium-webdriver": "^4.46.0",
    "storybook": "10.5.0",
    "typescript": "7.0.2",
    "web-ext": "10.5.0"
  }
}

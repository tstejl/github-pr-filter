{
  "name": "github-pr-filter",
  "version": "0.6.0",
  "private": true,
  "description": "A focused Chromium and Firefox extension for switching GitHub pull-request lifecycle views.",
  "homepage": "https://github.com/tstejl/github-pr-filter#readme",
  "bugs": {
    "url": "https://github.com/tstejl/github-pr-filter/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tstejl/github-pr-filter.git"
  },
  "scripts": {
    "build": "bun scripts/build-extension.ts",
    "storybook": "storybook dev --port 6006 --no-open",
    "storybook:build": "storybook build --output-dir dist/storybook",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint . --deny-warnings --report-unused-disable-directives",
    "lint:fix": "oxlint . --fix --deny-warnings --report-unused-disable-directives",
    "test": "bun run test:unit",
    "test:unit": "bun run build && bun test test",
    "test:coverage": "bun run build && bun test --coverage --coverage-reporter=lcov test",
    "coverage:update": "bun scripts/generate-coverage-badge.ts",
    "coverage:check": "bun scripts/generate-coverage-badge.ts --check",
    "test:e2e": "bun run test:e2e:chromium && bun run test:e2e:firefox",
    "test:e2e:chromium": "bun run build && E2E_BROWSER=chromium bun test ./e2e/lifecycle.e2e.ts",
    "test:e2e:firefox": "bun run build && E2E_BROWSER=firefox bun test ./e2e/lifecycle.e2e.ts",
    "test:visual": "bunx playwright test --config playwright.visual.config.ts",
    "check": "bun run format:check && bun run lint && tsc --noEmit",
    "lint:firefox": "bun run build && web-ext lint",
    "build:firefox": "bun run build && web-ext build --overwrite-dest",
    "release:package": "bun run build && bun scripts/package-release.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@storybook/addon-a11y": "10.5.0",
    "@storybook/html-vite": "10.5.0",
    "@types/bun": "1.3.11",
    "@types/selenium-webdriver": "^4.35.6",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "selenium-webdriver": "^4.46.0",
    "storybook": "10.5.0",
    "typescript": "7.0.2",
    "web-ext": "10.5.0"
  },
  "packageManager": "bun@1.3.11",
  "webExt": {
    "sourceDir": "dist/extension",
    "artifactsDir": "dist/firefox"
  }
}
